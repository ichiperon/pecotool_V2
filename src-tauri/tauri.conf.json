{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pecotool-v2",
  "version": "1.2.0",
  "identifier": "com.ichip.pecotool-v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PecoTool V2",
        "width": 1408,
        "height": 880
      },
      {
        "label": "preview-window",
        "title": "テキストコピー プレビュー",
        "url": "/#preview",
        "width": 600,
        "height": 800,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
