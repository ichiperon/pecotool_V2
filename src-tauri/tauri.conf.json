{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pecotool-v2",
  "version": "1.6.3",
  "identifier": "com.ichip.pecotool-v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PecoTool V2",
        "width": 1640,
        "height": 880
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data: http://asset.localhost https://asset.localhost; connect-src 'self' asset: blob: data: http://asset.localhost https://asset.localhost; worker-src 'self' blob:; object-src 'none';",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {},
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
